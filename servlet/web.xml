  xsi:schemaLocation="https://jakarta.ee/jakartaee
                      https://jakarta.ee/jakartaee/web-app/6.0/web-app 6.0"
  version="6.0">

    <servlet>
        <servlet-name>AutoMLServlet</servlet-name>
